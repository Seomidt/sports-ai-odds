# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:6543/postgres

# ─── Supabase Auth ────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── API-Football ingestion ───────────────────────────────────────────────────
API_FOOTBALL_KEY=

# ─── Anthropic (AI analysis) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=seomidt@gmail.com

# ─── Fase 1 feature flags ─────────────────────────────────────────────────────
# Limit tips to 1X2 / O2.5 / BTTS when true
PRIMARY_MARKETS_ONLY=true
# Minimum edge (decimal, e.g. 0.04 = 4 percentage points) required to publish a tip
EDGE_THRESHOLD=0.04

# ─── Fase 2 billing (keep all empty to run free-only) ─────────────────────────
# Set to true once Stripe is connected. When false, everyone is treated as Pro
# (no-op) and /api/billing/* returns 503.
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://your-domain/settings/billing?status=success
STRIPE_CANCEL_URL=https://your-domain/pricing?status=cancel
STRIPE_PORTAL_RETURN_URL=https://your-domain/settings/billing
